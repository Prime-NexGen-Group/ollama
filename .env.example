# Environment variables for Ollama
# Copy this to .env and adjust as needed:  cp .env.example .env

# Server bind address (default: 127.0.0.1:11434)
# OLLAMA_HOST=0.0.0.0:11434

# Model storage directory (default: ~/.ollama/models)
# OLLAMA_MODELS=/path/to/your/models

# How long to keep model loaded after last request (default: 5m)
OLLAMA_KEEP_ALIVE=10m

# Number of parallel requests (default: 1)
OLLAMA_NUM_PARALLEL=2

# Max models loaded in memory simultaneously (default: 1)
# OLLAMA_MAX_LOADED_MODELS=1

# Allowed CORS origins
# OLLAMA_ORIGINS=*
